# -----------------------------------------------------------
# Divulgacam · variáveis de ambiente
# Copie para .env.local e preencha com suas credenciais.
# -----------------------------------------------------------

# ── Supabase (obrigatório) ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── URL pública do app ──────────────────────────────────────
# Usada no botão de compartilhar e no callback de disparos.
NEXT_PUBLIC_APP_URL=https://divulgacam.com.br

# ── Resend (e-mail — Fase 3) ────────────────────────────────
# Obtenha em https://resend.com
RESEND_API_KEY=
# E-mail remetente padrão (pode ser sobrescrito por campanha em Configurações)
RESEND_FROM_EMAIL=contato@divulgacam.com.br

# ── Callback de disparos WhatsApp ──────────────────────────
# Secret compartilhado entre Divulgacam e n8n para o endpoint
# POST /api/blasts/update. Se não definido, o endpoint é aberto.
BLAST_CALLBACK_SECRET=

# ── Sincronização automática de leads (Google Sheets → n8n) ─
# Secret compartilhado entre Divulgacam e n8n para o endpoint
# POST /api/leads/sync. Se não definido, o endpoint é aberto.
LEADS_SYNC_SECRET=

# ── Evolution API ───────────────────────────────────────────
# Usado pelo n8n (não pelo app diretamente).
# Configure como credenciais no workflow n8n.
# EVOLUTION_API_URL=
# EVOLUTION_API_KEY=
